#!/usr/bin/env bash
set -euo pipefail

echo "==> gofmt"
GOFMT_OUT=$(gofmt -l .)
if [ -n "$GOFMT_OUT" ]; then
  echo "gofmt found unformatted files:"
  echo "$GOFMT_OUT"
  exit 1
fi

echo "==> go vet"
go vet ./...

echo "==> golangci-lint"
if command -v golangci-lint &>/dev/null; then
  golangci-lint run
else
  echo "golangci-lint not found, skipping"
fi

echo "==> go test"
go test ./... -race -coverprofile=coverage.out -covermode=atomic

echo "==> go build"
go build ./...

echo "==> all checks passed"
